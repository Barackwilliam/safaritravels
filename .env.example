# Copy this file to .env locally and fill in real values.
# NEVER commit the real .env file to git.

SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Supabase Postgres connection string
# Supabase dashboard -> Project Settings -> Database -> Connection string (URI)
# Use the "Session pooler" URI when deploying on Render.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Set to True once DB is confirmed reachable over SSL (Supabase requires SSL)
DB_SSL_REQUIRE=True

# Render sets this automatically in production — leave blank locally
RENDER_EXTERNAL_HOSTNAME=

CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# --- SEO -------------------------------------------------------------------
# Your live domain, no trailing slash — used for sitemap.xml & canonical tags
SITE_DOMAIN=https://safaritravels.co.tz
# GA4 measurement ID from Google Analytics (Admin -> Data Streams), e.g. G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=
# Verification code from Google Search Console (HTML tag method, content= value only)
GOOGLE_SITE_VERIFICATION=
# Google Maps "Embed a map" src URL, shown in the footer
SITE_MAP_EMBED_URL=https://www.google.com/maps?q=Bondeni+Street+Arusha+Tanzania&output=embed
